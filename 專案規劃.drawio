        <mxCell id="e3I59qlXLI7jxe0iIw4s-61" value="格式統一化 (Normalization)" style="whiteSpace=wrap;html=1;fontSize=24;fillColor=#9ACDE7;strokeColor=#45A1CF;fontColor=#4D4D4D;rounded=1;strokeWidth=3;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="860" y="1040" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e3I59qlXLI7jxe0iIw4s-62" value="分析 PDF 是 &quot;向量&quot; 還是 &quot;點陣&quot; 以及&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;檔案指紋分析： 統計檔案大小、建立日期、修改日期。&lt;/div&gt;&lt;div&gt;頁面屬性分析： 識別頁面尺寸（A4, A3, A0 等）、頁數。&lt;/div&gt;&lt;div&gt;解析度檢查： 對於光柵 PDF，計算其 DPI 分佈，篩除模糊無法辨識的壞檔。&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fontSize=24;fillColor=#9ACDE7;strokeColor=#45A1CF;fontColor=#4D4D4D;rounded=1;strokeWidth=3;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="840" width="840" height="160" as="geometry" />
        </mxCell>
        <mxCell id="e3I59qlXLI7jxe0iIw4s-63" value="ROI 提取(Region of Interest Extraction)" style="whiteSpace=wrap;html=1;fontSize=24;fillColor=#9ACDE7;strokeColor=#45A1CF;fontColor=#4D4D4D;rounded=1;strokeWidth=3;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1520" y="880" width="480" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
